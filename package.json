{
  "name": "restaurants-lookup-yelp-api",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "env": "node scripts/setup-env.mjs",
    "setup": "npm install && npm run env",
    "dev": "concurrently -n client,server -c blue,green \"npm run dev -w client\" \"npm run dev -w server\"",
    "dev:client": "npm run dev -w client",
    "dev:server": "npm run dev -w server",
    "build": "npm run build -w client",
    "lint": "npm run lint -w client && npm run lint -w server",
    "test": "npm run test -w server"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
